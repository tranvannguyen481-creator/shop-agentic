# Server
PORT=5000
LOG_LEVEL=info

# Firebase Admin (required)
# Option 1 (local): relative path to service account file
FIREBASE_SERVICE_ACCOUNT_KEY=./service-account-key.json

# Option 2 (production): JSON string secret (do not keep both)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

FIREBASE_PROJECT_ID=shop-agentic

# Encryption key for group share-link tokens (AES-256-GCM)
# Generate a 32-byte hex key:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GROUP_LINK_SECRET=your-32-byte-hex-key-here
